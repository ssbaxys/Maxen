{
    "rules": {
        ".read": false,
        ".write": false,
        "users": {
            "$uid": {
                ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('root').val() === true)",
                ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('root').val() === true)",
                "root": {
                    ".write": false
                }
            }
        },
        "usernames": {
            ".read": "auth != null",
            "$username": {
                ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
            }
        },
        "servers": {
            "$serverId": {
                ".read": "auth != null && (data.child('owner').val() === auth.uid || root.child('serverMembers').child($serverId).child(auth.uid).exists() || root.child('users').child(auth.uid).child('root').val() === true)",
                ".write": "auth != null && (data.child('owner').val() === auth.uid || (data.exists() === false && newData.child('owner').val() === auth.uid) || root.child('users').child(auth.uid).child('root').val() === true)"
            }
        },
        "serverMembers": {
            "$serverId": {
                ".read": "auth != null && (root.child('servers').child($serverId).child('owner').val() === auth.uid || data.child(auth.uid).exists() || root.child('users').child(auth.uid).child('root').val() === true)",
                ".write": "auth != null && (root.child('servers').child($serverId).child('owner').val() === auth.uid || root.child('users').child(auth.uid).child('root').val() === true)"
            }
        },
        "logs": {
            "$serverId": {
                ".read": "auth != null && (root.child('servers').child($serverId).child('owner').val() === auth.uid || root.child('serverMembers').child($serverId).child(auth.uid).exists() || root.child('users').child(auth.uid).child('root').val() === true)",
                ".write": false
            }
        },
        "stats": {
            "$serverId": {
                ".read": "auth != null && (root.child('servers').child($serverId).child('owner').val() === auth.uid || root.child('serverMembers').child($serverId).child(auth.uid).exists() || root.child('users').child(auth.uid).child('root').val() === true)",
                ".write": false
            }
        },
        "settings": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('users').child(auth.uid).child('root').val() === true"
        },
        "bans": {
            ".read": "auth != null && root.child('users').child(auth.uid).child('root').val() === true",
            ".write": "auth != null && root.child('users').child(auth.uid).child('root').val() === true"
        }
    }
}