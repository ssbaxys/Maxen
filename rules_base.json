{
    "rules": {
        "users": {
            "$uid": {
                ".read": "$uid === auth.uid || root.child('users/' + auth.uid + '/root').val() === true",
                ".write": "$uid === auth.uid || root.child('users/' + auth.uid + '/root').val() === true",
                "root": {
                    ".write": false
                }
            }
        },
        "servers": {
            ".read": "auth != null",
            "$serverId": {
                ".write": "root.child('users/' + auth.uid + '/root').val() === true",
                "users": {
                    "$uid": {
                        ".write": "$uid === auth.uid"
                    }
                }
            }
        },
        "systemLogs": {
            ".read": "root.child('users/' + auth.uid + '/root').val() === true",
            ".write": "root.child('users/' + auth.uid + '/root').val() === true"
        }
    }
}